## 📦 9. Imports y Exports

### Orden de Imports

```typescript
// 1. React y React Native
import React, { useState, useEffect } from 'react';
import { View, Text, Pressable } from 'react-native';

// 2. Librerías externas
import { useQuery } from '@tanstack/react-query';
import { useRouter } from 'expo-router';
import { useColorScheme } from 'nativewind';

// 3. Alias de proyecto (@/)
import { Button } from '@/components/ui/button';
import { useAuth } from '@/hooks/useAuth';

// 4. Relativos
import { ProductCard } from './ProductCard';
import { calculateTotal } from '../utils/calculations';
import type { ProductListProps } from './ProductList.types';

// 5. Styles (si aplica)
import { styles } from './ProductList.styles';
```

### Named Exports vs Default Export

```typescript
✅ CORRECTO: Named exports para componentes
// Button.tsx
export function Button({ title, onPress }: ButtonProps) {
  return <Pressable onPress={onPress}>...</Pressable>;
}

// Import
import { Button } from '@/components/ui/Button';

✅ TAMBIÉN OK: Default export para páginas/screens (Expo Router lo prefiere)
// app/(tabs)/index.tsx
export default function DashboardScreen() {
  return <View>...</View>;
}

❌ EVITAR: Mezclar ambos sin razón
export function Button() {}
export default Button; // Redundante
```

