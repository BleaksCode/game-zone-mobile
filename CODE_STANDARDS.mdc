## 🎨 4. TypeScript

### Interfaces vs Types

```typescript
✅ CORRECTO: Usa interfaces para objetos, types para unions/intersections

// Interfaces para objetos y React props
interface User {
  id: string;
  name: string;
  email: string;
}

interface ButtonProps {
  title: string;
  onPress: () => void;
}

// Types para unions, intersections, mapped types
type Status = 'idle' | 'loading' | 'success' | 'error';
type UserWithRole = User & { role: string };
type Optional<T> = { [K in keyof T]?: T[K] };

❌ INCORRECTO:
type User = {  // Usa interface
  id: string;
}

interface Status = 'idle' | 'loading'; // No válido
```

### Tipado Explícito

```typescript
✅ CORRECTO: Tipar parámetros y retornos complejos
function calculateTotal(items: Product[]): number {
  return items.reduce((sum, item) => sum + item.price, 0);
}

const fetchUser = async (id: string): Promise<User> => {
  const response = await api.get(`/users/${id}`);
  return response.data;
};

// Inferencia está OK para casos simples
const count = 10; // number inferido
const name = 'Juan'; // string inferido

❌ INCORRECTO:
function calculateTotal(items: any): any { // Evita any
  return items.reduce((sum: any, item: any) => sum + item.price, 0);
}
```

### Never Use `any`

```typescript
❌ EVITAR:
const data: any = await fetchData();
function handleEvent(event: any) {}

✅ ALTERNATIVAS:
const data: unknown = await fetchData(); // Para validar después
const data = (await fetchData()) as User; // Si sabes el tipo

function handleEvent(event: PressEvent) {} // Tipo específico
function handleEvent<T>(event: T) {} // Genérico si es necesario
```

