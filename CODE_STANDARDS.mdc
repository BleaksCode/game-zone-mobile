## 🧩 10. Componentes y Props

### Props Destructuring

```typescript
✅ CORRECTO:
interface ButtonProps {
  title: string;
  variant?: 'primary' | 'secondary';
  onPress: () => void;
}

export function Button({
  title,
  variant = 'primary',
  onPress
}: ButtonProps) {
  return <Pressable onPress={onPress}>...</Pressable>;
}

❌ INCORRECTO:
export function Button(props: ButtonProps) {
  return <Pressable onPress={props.onPress}>...</Pressable>;
}
```

### Children Props

```typescript
✅ CORRECTO:
interface CardProps {
  children: React.ReactNode;
  title?: string;
}

export function Card({ children, title }: CardProps) {
  return (
    <View>
      {title && <Text>{title}</Text>}
      {children}
    </View>
  );
}
```

